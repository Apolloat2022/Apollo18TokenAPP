# --- Phase 2 (v3.2): Neon + Clerk + Stripe + Coinbase Commerce ---

# Client-safe (shipped to the browser). From Clerk → API Keys.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Server-only (NEVER prefix these with EXPO_PUBLIC — they must stay out of the
# bundle). Set them in the Vercel project's Environment Variables.
CLERK_SECRET_KEY=sk_test_...

# Neon pooled connection string (Neon dashboard → Connection Details → Pooled).
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Absolute base URL for checkout success/cancel redirects (e.g. https://www.apollo18token.com)
SITE_URL=https://www.apollo18token.com

# Stripe Price ids per SKU (create Products in Stripe, then paste the price_... ids).
STRIPE_PRICE_COURSE_PROMPT_MASTERY=price_...
STRIPE_PRICE_CREDITS_500=price_...
STRIPE_PRICE_CREDITS_2500=price_...
STRIPE_PRICE_CREDITS_10000=price_...

# --- ETH rail: Coinbase Commerce (server-only) ---
# From Coinbase Commerce → Settings → Security (API key) and Webhook subscriptions (shared secret).
COINBASE_COMMERCE_API_KEY=your-commerce-api-key
COINBASE_COMMERCE_WEBHOOK_SECRET=your-commerce-webhook-shared-secret
