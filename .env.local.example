# --- Phase 2: Supabase + Stripe ---

# Client-safe (shipped to the browser). From Supabase → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (NEVER prefix these with EXPO_PUBLIC — they must stay out of the bundle).
# Set them in the Vercel project's Environment Variables, not in the client build.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Absolute base URL for Stripe success/cancel redirects (e.g. https://www.apollo18token.com)
SITE_URL=https://www.apollo18token.com

# Stripe Price ids per SKU (create Products in Stripe, then paste the price_... ids).
STRIPE_PRICE_COURSE_PROMPT_MASTERY=price_...
STRIPE_PRICE_CREDITS_500=price_...
STRIPE_PRICE_CREDITS_2500=price_...
STRIPE_PRICE_CREDITS_10000=price_...

# --- ETH rail: Coinbase Commerce (server-only) ---
# From Coinbase Commerce → Settings → Security (API key) and Webhook subscriptions (shared secret).
COINBASE_COMMERCE_API_KEY=your-commerce-api-key
COINBASE_COMMERCE_WEBHOOK_SECRET=your-commerce-webhook-shared-secret
